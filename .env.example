GOOGLE_DRIVE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_DRIVE_REDIRECT_URI="http://localhost:8888/api/v1/google-drive/callback"
GOOGLE_DRIVE_STATE_SECRET="replace-with-a-random-secret"
GOOGLE_DRIVE_TOKEN_SECRET="replace-with-a-random-secret"

# Optional Google Drive settings
GOOGLE_DRIVE_FOLDER_NAME="refhub"
GOOGLE_DRIVE_MAX_UPLOAD_BYTES="26214400"
