SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
REFHUB_API_KEY_PEPPER="replace-with-a-random-secret"

# Optional app/runtime settings
REFHUB_APP_BASE_URL="http://localhost:3000"
REFHUB_API_ALLOWED_ORIGINS="http://localhost:3000,https://refhub.io"
